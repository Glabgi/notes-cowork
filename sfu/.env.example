# Скопируйте в `.env` и подставьте свои значения
# cp .env.example .env

# Публичный IPv4 этого VPS (обязательно)
ANNOUNCED_IP=203.0.113.10

# Сигнальный порт (HTTP/WS)
SFU_PORT=4000

# Диапазон UDP/TCP портов для RTP/RTCP медиа
RTC_MIN_PORT=40000
RTC_MAX_PORT=40100

# Воркеры — по одному на CPU-ядро (обычно 2-4)
NUM_WORKERS=2

# warn / debug / error
MS_LOG_LEVEL=warn
